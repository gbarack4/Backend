# ==========================================
# DATABASE (PostgreSQL / Drizzle ORM)
# ==========================================
# Connection string to your PostgreSQL database.
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL=
MIGRATION_DATABASE_URL=

# ==========================================
# CLERK AUTHENTICATION
# ==========================================
# Frontend API URL. Found in Clerk Dashboard -> API Keys.
# Example: https://clever-monkey-12.clerk.accounts.dev
CLERK_ISSUER=

# Backend Secret Key. Found in Clerk Dashboard -> API Keys.
# Must start with 'sk_test_' or 'sk_live_'
CLERK_SECRET_KEY=

# Webhook Secret for verifying incoming events from Clerk.
# Found in Clerk Dashboard -> Webhooks -> Endpoint Secret.
# Must start with 'whsec_'
CLERK_WEBHOOK_SECRET=

# Example: http://localhost:3000,https://admin.your-domain.com
ALLOWED_ORIGINS=

# ==========================================
# AWS S3 STORAGE
# ==========================================
# The AWS region where your S3 bucket is located (e.g., us-east-1)
AWS_REGION=

# The unique name of your S3 bucket
AWS_S3_BUCKET_NAME=

# IAM User Access Key ID with S3 permissions
AWS_ACCESS_KEY_ID=

# IAM User Secret Access Key
AWS_SECRET_ACCESS_KEY=

# ==========================================
# GOOGLE OAUTH & BUSINESS API
# ==========================================
# OAuth 2.0 Client ID from Google Cloud Console
GOOGLE_CLIENT_ID=

# OAuth 2.0 Client Secret from Google Cloud Console
GOOGLE_CLIENT_SECRET=

# The Redirect URI registered in Google Cloud Console (APIs & Services -> Credentials).
# MUST match 'Authorized redirect URIs' in Google Console exactly (protocol, domain, path).
# Note: Any mismatch (http vs https, missing trailing slash) will cause a 400 error.
# Local Example: http://localhost:8000/google/callback
# Prod Example:  https://api.drivinginstructor.pro/google/callback
GOOGLE_CALLBACK_URL=

# A strong, random string used for HMAC signing the OAuth state parameter to prevent CSRF attacks
GOOGLE_STATE_SECRET=

GOOGLE_TIMEZONE_API_KEY=

# ==========================================
# APP SETTINGS
# ==========================================
# The base URL of your frontend application
FRONTEND_URL=